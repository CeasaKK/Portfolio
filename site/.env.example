# Keystatic production editing (GitHub App). Not needed for local editing.
# Fill these in Vercel → Settings → Environment Variables after creating the
# Keystatic GitHub App (see README "Editing content in production").
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
